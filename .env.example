# --- LLM APIs ---
GROQ_API_KEY=gsk_your_groq_api_key_here
FALL_GROQ_API_KEY=gsk_your_fallback_groq_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# --- Vector Database (Qdrant) ---
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_END_POINT=https://your-qdrant-endpoint-here.aws.cloud.qdrant.io
QDRANT_CLUSTER_ID=your_qdrant_cluster_id_here

# --- Ingestion & Documents ---
# PDF resume file path (defaults to assets/Muhammad_Umer_Khan_AI_Resume.pdf)
RESUME_PATH=assets/Muhammad_Umer_Khan_AI_Resume.pdf

# --- Models ---
MODEL_NAME=openai/gpt-oss-120b
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# --- GitHub Source Fetcher (Phase 1) ---
# Fine-grained PAT with read-only Contents + Metadata access
GITHUB_TOKEN=github_pat_your_github_token_here
GITHUB_USERNAME=your_github_username_here

# --- Observability & Tracing (Logfire & LangSmith) ---
LOGFIRE_TOKEN=pylf_v2_your_logfire_token_here

LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true

# --- Cache & Temp Directories ---
HF_HOME=/tmp/huggingface